<div class="rb-edit-wrap">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700;900&display=swap');

        .rb-edit-wrap {
            padding: 12px;
            font-family: var(--font-primary);
            background: linear-gradient(160deg, #1c0905 0%, #250b04 100%);
            color: #c06030;
        }

        .rb-field { margin-bottom: 12px; }

        .rb-field > label,
        .rb-field > legend {
            display: block;
            font-family: 'Cinzel', Georgia, serif;
            font-weight: 700;
            font-size: 9px;
            text-transform: uppercase;
            letter-spacing: .1em;
            color: #8a4020;
            margin-bottom: 5px;
        }

        .rb-field input[type="text"],
        .rb-field input[type="number"],
        .rb-field select {
            width: 100%;
            background: rgba(0,0,0,0.5) !important;
            border: 1px solid rgba(139,48,0,0.6) !important;
            border-radius: 4px !important;
            color: #ff8040 !important;
        }
        .rb-field input[type="text"]:focus,
        .rb-field input[type="number"]:focus,
        .rb-field select:focus {
            border-color: #c83000 !important;
            box-shadow: 0 0 6px rgba(200,48,0,0.4) !important;
            outline: none;
        }
        .rb-field select option {
            background: #1a0804;
            color: #ff8040;
        }

        .rb-hint {
            font-size: 10px;
            color: #6a3818;
            margin-top: 4px;
            font-style: italic;
            line-height: 1.4;
        }

        .rb-section {
            background: rgba(0,0,0,0.3);
            border: 1px solid rgba(139,48,0,0.4);
            border-radius: 6px;
            padding: 10px 12px;
            margin-bottom: 12px;
        }
        .rb-section > legend {
            font-family: 'Cinzel', Georgia, serif;
            font-weight: 700;
            font-size: 9px;
            text-transform: uppercase;
            letter-spacing: .1em;
            color: #8a4020;
            margin-bottom: 8px;
            display: block;
        }
        .rb-section .rb-field { margin-bottom: 8px; }
        .rb-section .rb-field:last-child { margin-bottom: 0; }

        .rb-events-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 5px 16px;
        }

        .rb-check-label {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            font-size: 12px;
            color: #c06030;
            cursor: pointer;
            padding: 2px 0;
        }
        .rb-check-label input[type="checkbox"] {
            margin: 0;
            width: auto;
            cursor: pointer;
            accent-color: #c83000;
        }

        .rb-check-group {
            display: flex;
            flex-wrap: wrap;
            gap: 5px 14px;
        }
        .rb-check-group .rb-check-label { font-size: 11px; }

        .rb-inline {
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .rb-inline input[type="checkbox"] {
            margin: 0;
            width: auto;
            cursor: pointer;
            accent-color: #c83000;
        }
        .rb-inline label {
            font-weight: 500;
            font-size: 12px;
            color: #c06030;
            cursor: pointer;
        }

        .rb-divider {
            border: none;
            border-top: 1px solid rgba(139,48,0,0.3);
            margin: 12px 0;
        }
    </style>

    <div class="rb-field">
        <label>{{localize "resource-bridge.edit.name"}}</label>
        <input type="text" name="name" value="{{trigger.name}}"
               placeholder="{{localize "resource-bridge.edit.namePlaceholder"}}">
    </div>

    <fieldset class="rb-section">
        <legend>{{localize "resource-bridge.edit.events"}}</legend>
        <div class="rb-events-grid">
            {{#each eventOptions}}
                <label class="rb-check-label">
                    <input type="checkbox" name="events.{{value}}" {{#if checked}}checked{{/if}}>
                    {{label}}
                </label>
            {{/each}}
        </div>
    </fieldset>

    {{#if showItemFilter}}
        <div class="rb-field">
            <label>{{localize "resource-bridge.edit.itemFilter"}}</label>
            <input type="text" name="sourceItemFilter" value="{{trigger.sourceItemFilter}}"
                   placeholder="{{localize "resource-bridge.edit.itemFilterPlaceholder"}}">
            <p class="rb-hint">{{localize "resource-bridge.edit.itemFilterHint"}}</p>
        </div>
    {{/if}}

    <hr class="rb-divider">

    <div class="rb-field">
        <label>{{localize "resource-bridge.edit.action"}}</label>
        <select name="action">
            {{#each actionOptions}}
                <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
            {{/each}}
        </select>
    </div>

    {{#if showResource}}
        <div class="rb-section">
            <div class="rb-field">
                <label>{{localize "resource-bridge.edit.targetResource"}}</label>
                <select name="targetResource">
                    {{#each resourceOptions}}
                        <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                    {{/each}}
                </select>
            </div>
        </div>
    {{/if}}

    {{#if showItem}}
        <div class="rb-section">
            <div class="rb-field">
                <label>{{localize "resource-bridge.edit.targetItem"}}</label>
                <input type="text" name="targetItem" value="{{trigger.targetItem}}"
                       placeholder="{{localize "resource-bridge.edit.targetItemPlaceholder"}}">
                <p class="rb-hint">{{localize "resource-bridge.edit.targetItemHint"}}</p>
            </div>
            <div class="rb-field">
                <label>{{localize "resource-bridge.edit.useMode"}}</label>
                <select name="itemUseMode">
                    {{#each useModeOptions}}
                        <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                    {{/each}}
                </select>
                <p class="rb-hint">{{localize "resource-bridge.edit.useModeHint"}}</p>
            </div>
        </div>
    {{/if}}

    <hr class="rb-divider">

    <div style="display:flex; gap:16px; align-items:flex-end;">
        <div class="rb-field" style="flex:0 0 100px; margin-bottom:0;">
            <label>{{localize "resource-bridge.edit.delta"}}</label>
            <input type="number" name="delta" value="{{trigger.delta}}" min="1" step="1">
        </div>
        <div class="rb-inline" style="padding-bottom:5px; flex:1;">
            <input type="checkbox" name="oncePerRound" id="rb-opr" {{#if trigger.oncePerRound}}checked{{/if}}>
            <label for="rb-opr">{{localize "resource-bridge.edit.oncePerRound"}}</label>
        </div>
    </div>

    {{#if showExcludeTypes}}
        <fieldset class="rb-section" style="margin-top:12px;">
            <legend>{{localize "resource-bridge.edit.excludeTypes"}}</legend>
            <div class="rb-check-group">
                {{#each creatureTypeOptions}}
                    <label class="rb-check-label">
                        <input type="checkbox" name="excludeTypes.{{value}}" {{#if checked}}checked{{/if}}>
                        {{label}}
                    </label>
                {{/each}}
            </div>
            <p class="rb-hint">{{localize "resource-bridge.edit.excludeTypesHint"}}</p>
        </fieldset>
    {{/if}}

</div>
