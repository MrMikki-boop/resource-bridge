<div class="rb-edit-wrap">
  <style>
    .rb-edit-wrap { padding: 4px 2px; font-family: var(--font-primary); }
    .rb-field { margin-bottom: 10px; }
    .rb-field > label, .rb-field > legend { display: block; font-weight: bold; font-size: 11px; margin-bottom: 3px; color: #444; text-transform: uppercase; letter-spacing: .03em; }
    .rb-field input[type="text"], .rb-field input[type="number"], .rb-field select { width: 100%; }
    .rb-field.rb-inline { display: flex; align-items: center; gap: 8px; }
    .rb-field.rb-inline input[type="checkbox"] { margin: 0; width: auto; }
    .rb-field.rb-inline label { font-weight: normal; font-size: 12px; margin: 0; text-transform: none; cursor: pointer; }
    .rb-check-group { display: flex; flex-wrap: wrap; gap: 5px 14px; margin-top: 4px; }
    .rb-check-label { display: inline-flex; align-items: center; gap: 5px; font-size: 12px; font-weight: normal; cursor: pointer; }
    .rb-check-label input { margin: 0; width: auto; }
    .rb-section { background: rgba(0,0,0,.03); border: 1px solid #ddd; border-radius: 4px; padding: 8px 10px; margin-bottom: 8px; }
    .rb-section legend { font-weight: bold; font-size: 11px; color: #555; text-transform: uppercase; }
    .rb-hint { font-size: 10px; color: #888; margin-top: 2px; font-style: italic; }
  </style>

  <div class="rb-field">
    <label>{{localize "resource-bridge.edit.name"}}</label>
    <input type="text" name="name" value="{{trigger.name}}" placeholder="{{localize "resource-bridge.edit.namePlaceholder"}}">
  </div>

  <div class="rb-field">
    <label>{{localize "resource-bridge.edit.event"}}</label>
    <select name="event">
      {{#each eventOptions}}
        <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
      {{/each}}
    </select>
  </div>

  {{#if showItemFilter}}
  <div class="rb-field">
    <label>{{localize "resource-bridge.edit.itemFilter"}}</label>
    <input type="text" name="sourceItemFilter" value="{{trigger.sourceItemFilter}}" placeholder="{{localize "resource-bridge.edit.itemFilterPlaceholder"}}">
    <p class="rb-hint">{{localize "resource-bridge.edit.itemFilterHint"}}</p>
  </div>
  {{/if}}

  <div class="rb-field">
    <label>{{localize "resource-bridge.edit.action"}}</label>
    <select name="action">
      {{#each actionOptions}}
        <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
      {{/each}}
    </select>
  </div>

  {{#if showResource}}
  <div class="rb-section">
    <div class="rb-field">
      <label>{{localize "resource-bridge.edit.targetResource"}}</label>
      <select name="targetResource">
        {{#each resourceOptions}}
          <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
        {{/each}}
      </select>
    </div>
  </div>
  {{/if}}

  {{#if showItem}}
  <div class="rb-section">
    <div class="rb-field">
      <label>{{localize "resource-bridge.edit.targetItem"}}</label>
      <input type="text" name="targetItem" value="{{trigger.targetItem}}" placeholder="{{localize "resource-bridge.edit.targetItemPlaceholder"}}">
    </div>
    <div class="rb-field">
      <label>{{localize "resource-bridge.edit.useMode"}}</label>
      <select name="itemUseMode">
        {{#each useModeOptions}}
          <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
        {{/each}}
      </select>
        <!--      <p class="rb-hint">{{localize "resource-bridge.edit.useModeHint"}}</p>-->
    </div>
  </div>
  {{/if}}

  <div class="rb-field">
    <label>{{localize "resource-bridge.edit.delta"}}</label>
    <input type="number" name="delta" value="{{trigger.delta}}" min="1" step="1">
  </div>

  <div class="rb-field rb-inline">
    <input type="checkbox" name="oncePerRound" id="rb-opr" {{#if trigger.oncePerRound}}checked{{/if}}>
    <label for="rb-opr">{{localize "resource-bridge.edit.oncePerRound"}}</label>
  </div>

  {{#if showExcludeTypes}}
  <fieldset class="rb-section">
    <legend>{{localize "resource-bridge.edit.excludeTypes"}}</legend>
    <div class="rb-check-group">
      {{#each creatureTypeOptions}}
        <label class="rb-check-label">
          <input type="checkbox" name="excludeTypes.{{value}}" {{#if checked}}checked{{/if}}>
          {{label}}
        </label>
      {{/each}}
    </div>
    <p class="rb-hint">{{localize "resource-bridge.edit.excludeTypesHint"}}</p>
  </fieldset>
  {{/if}}

</div>
